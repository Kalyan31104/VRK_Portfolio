PORT=3000

# SMTP settings
# Use your email provider SMTP details.
# Gmail example is prefilled below.
# For other providers, check their SMTP docs.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Sender account (the account used by backend to send mail)
# For Gmail: use your Gmail address.
SMTP_USER=your-email@gmail.com

# SMTP password / token
# For Gmail: this must be an App Password (not your normal Gmail password).
# How to get App Password:
# 1) Google Account -> Security -> turn on 2-Step Verification
# 2) Security -> App passwords -> select Mail + Other device -> generate
# 3) Paste generated 16-char password below
SMTP_PASS=your-app-password

# Where messages should be delivered
# This can be same as SMTP_USER or any inbox you want to receive contact messages.
CONTACT_TO_EMAIL=vuppureddykalyan@gmail.com
